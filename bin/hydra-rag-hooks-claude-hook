#!/usr/bin/env python3
# hydra-rag-hooks-claude-hook: the UserPromptSubmit hook entrypoint that
# Claude Code invokes via /etc/claude-code/managed-settings.json.
#
# Not on $PATH. Lives at /usr/lib/hydra-rag-hooks/hydra-rag-hooks-claude-hook.
# End users never invoke this directly; Claude Code does.

import os
import sys


def _bootstrap_sys_path() -> None:
    # Use the FIRST candidate that has the package, not all of them. A
    # half-installed older package at /usr/lib/hydra-rag-hooks/ must not
    # shadow the package shipped next to this script.
    here = os.path.dirname(os.path.realpath(__file__))
    for c in (here,
              os.path.normpath(os.path.join(here, "..", "lib")),
              "/usr/lib/hydra-rag-hooks"):
        if os.path.isdir(os.path.join(c, "hydra_rag_hooks")):
            if c not in sys.path:
                sys.path.insert(0, c)
            return


_bootstrap_sys_path()

from hydra_rag_hooks.hook import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
