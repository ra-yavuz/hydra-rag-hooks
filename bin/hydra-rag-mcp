#!/usr/bin/env python3
# hydra-rag-mcp: stdio MCP server entrypoint.
#
# Wired into Claude Code per-user via ~/.claude.json mcpServers entry,
# auto-registered by the hook on first run. End users do not invoke
# this directly; Claude Code does.
#
# Lives at /usr/lib/hydra-rag-hooks/hydra-rag-mcp. Not on $PATH.

import os
import sys


def _bootstrap_sys_path() -> None:
    here = os.path.dirname(os.path.realpath(__file__))
    for c in (here,
              os.path.normpath(os.path.join(here, "..", "lib")),
              "/usr/lib/hydra-rag-hooks"):
        if os.path.isdir(os.path.join(c, "hydra_rag_hooks")):
            if c not in sys.path:
                sys.path.insert(0, c)
            return


_bootstrap_sys_path()

from hydra_rag_hooks.mcp import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
